{
  "name": "yourpelvic-healing",
  "version": "1.0.0",
  "description": "Your Pelvic Healing \u2014 the complete, un-embarrassing guide to pelvic floor health",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "bulk-seed": "node scripts/bulk-seed.mjs",
    "normalize": "node scripts/normalize-articles.mjs",
    "migrate-images": "python3 scripts/migrate-images-to-bunny.py",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "check": "node scripts/check-counts.mjs",
    "audit": "node scripts/audit.mjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "openai": "^4.47.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
